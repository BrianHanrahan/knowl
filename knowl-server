#!/usr/bin/env bash
# knowl-server — start/stop/restart the Knowl web UI server
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$PROJECT_DIR/.venv"
PIDFILE="$PROJECT_DIR/.knowl-server.pid"
LOGFILE="$PROJECT_DIR/.knowl-server.log"
PORT="${KNOWL_PORT:-6060}"

usage() {
    echo "Usage: knowl-server {start|stop|restart|status}"
    echo ""
    echo "Options (env vars):"
    echo "  KNOWL_PORT   Server port (default: 6060)"
    echo "  KNOWL_DEV    Set to 1 for dev mode with CORS (default: 0)"
    exit 1
}

is_running() {
    [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

do_start() {
    if is_running; then
        echo "Knowl server already running (PID $(cat "$PIDFILE")) on port $PORT"
        return 0
    fi

    if [ ! -d "$VENV" ]; then
        echo "Error: virtualenv not found at $VENV"
        echo "Run: python3 -m venv .venv && pip install -r requirements.txt"
        exit 1
    fi

    # Strip Claude Code env vars so the CLI backend's Agent SDK can spawn its own session
    unset CLAUDECODE 2>/dev/null || true
    unset CLAUDE_CODE_ENTRYPOINT 2>/dev/null || true

    DEV_FLAG="${KNOWL_DEV:-0}"
    if [ "$DEV_FLAG" = "1" ]; then
        DEV_ARG="True"
    else
        DEV_ARG="False"
    fi

    echo "Starting Knowl server on http://localhost:$PORT ..."
    nohup "$VENV/bin/python" -c "
import uvicorn
from knowl.ui.server import create_app
app = create_app(dev=$DEV_ARG)
uvicorn.run(app, host='0.0.0.0', port=$PORT)
" > "$LOGFILE" 2>&1 &

    echo $! > "$PIDFILE"
    sleep 1

    if is_running; then
        echo "Knowl server started (PID $(cat "$PIDFILE"))"
        echo "Log: $LOGFILE"
    else
        echo "Failed to start. Check log: $LOGFILE"
        rm -f "$PIDFILE"
        exit 1
    fi
}

do_stop() {
    if ! is_running; then
        echo "Knowl server is not running"
        rm -f "$PIDFILE"
        return 0
    fi

    PID=$(cat "$PIDFILE")
    echo "Stopping Knowl server (PID $PID) ..."
    kill "$PID"

    # Wait up to 5 seconds for graceful shutdown
    for i in $(seq 1 10); do
        if ! kill -0 "$PID" 2>/dev/null; then
            break
        fi
        sleep 0.5
    done

    # Force kill if still running
    if kill -0 "$PID" 2>/dev/null; then
        echo "Force killing ..."
        kill -9 "$PID" 2>/dev/null || true
    fi

    rm -f "$PIDFILE"
    echo "Stopped"
}

do_status() {
    if is_running; then
        echo "Knowl server is running (PID $(cat "$PIDFILE")) on port $PORT"
    else
        echo "Knowl server is not running"
        rm -f "$PIDFILE"
    fi
}

[ $# -lt 1 ] && usage

case "$1" in
    start)   do_start ;;
    stop)    do_stop ;;
    restart) do_stop; do_start ;;
    status)  do_status ;;
    *)       usage ;;
esac
